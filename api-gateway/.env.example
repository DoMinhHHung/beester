# Application
APP_ENV=development
HTTP_ADDR=:8080
GRPC_ADDR=:9090
MAX_REQUEST_BODY_BYTES=8388608
UPSTREAM_REQUEST_TIMEOUT=30s

# HTTP reverse proxy. Format: name=url,name=url
HTTP_UPSTREAMS=
# Format: METHOD:/path/pattern=upstream,METHOD:/other=upstream
# Go 1.22+ ServeMux patterns are supported, e.g. GET:/api/users/{id}=users
HTTP_ROUTES=

# Native gRPC passthrough proxy. Format: name=target,name=target
GRPC_TRANSPORT_SECURITY=insecure
GRPC_UPSTREAMS=
# Format: /package.Service/=upstream,/other.Service/=upstream
GRPC_ROUTES=

# JWT authentication (HS256 in v1)
JWT_ENABLED=false
JWT_HMAC_SECRET=
JWT_ISSUER=
JWT_AUDIENCE=
JWT_USER_ID_CLAIM=sub
JWT_USER_ID_HEADER=X-User-ID
JWT_FORWARD_AUTHORIZATION=false
JWT_PUBLIC_PATH_PREFIXES=/healthz,/readyz,/api/auth/
JWT_PUBLIC_GRPC_METHOD_PREFIXES=
JWT_LEEWAY=30s

# Redis token-bucket rate limiting
RATE_LIMIT_ENABLED=false
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
RATE_LIMIT_CAPACITY=100
RATE_LIMIT_REFILL_PER_SECOND=50
RATE_LIMIT_KEY_PREFIX=beester:ratelimit
RATE_LIMIT_FAIL_OPEN=false
# Only enable when BeeSter is behind a trusted proxy that overwrites forwarding headers.
TRUST_PROXY_HEADERS=false
